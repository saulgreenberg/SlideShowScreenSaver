<Window x:Class="SlideShowScreenSaver.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:SlideShowScreenSaver"
        Title="MainWindow"
        Background="Black"
        KeyDown="Window_KeyDown"
        MouseDown="Window_MouseDown"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowState="Maximized"
        WindowStyle="None"
        Loaded="MainWindow_Loaded">

    <Window.Resources>
        <!-- The FadeIn / FadeOut animations -->
        <!-- ReSharper disable once Xaml.RedundantResource -->
        <Storyboard x:Key="FadeIn">
            <DoubleAnimation Duration="0:0:.75" Storyboard.TargetProperty="Opacity" From="0" To="1">
            </DoubleAnimation>
        </Storyboard>

        <!-- ReSharper disable once Xaml.RedundantResource -->
        <Storyboard x:Key="FadeOut">
            <DoubleAnimation Duration="0:0:.75" Storyboard.TargetProperty="Opacity" To="0">
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

    <Canvas Name="RootCanvas" Background="Black" ClipToBounds="True">
        <Image x:Name="Image1" Stretch="Uniform"  Width="{Binding Path=ActualWidth, ElementName=RootCanvas}" Height="{Binding Path=ActualHeight, ElementName=RootCanvas}"  RenderTransformOrigin="0.5,0.5" >
            <Image.RenderTransform>
                <TransformGroup>
                    <TranslateTransform X="0" Y="0">
                    </TranslateTransform>
                </TransformGroup>
            </Image.RenderTransform>
        </Image>
        <Image x:Name="Image2" Stretch="Uniform"  Width="{Binding Path=ActualWidth, ElementName=RootCanvas}" Height="{Binding Path=ActualHeight, ElementName=RootCanvas}"  RenderTransformOrigin="0.5,0.5" >
            <Image.RenderTransform>
                <TransformGroup>
                    <TranslateTransform X="0" Y="0">
                    </TranslateTransform>
                </TransformGroup>
            </Image.RenderTransform>
        </Image>

        <!-- Text graphics that uses an outline font-->
        <!--We could specify the font if we wanted to: FontFamily="SegoeUI"-->
        <local:TextPath x:Name="DisplayText" Margin="10,0,0,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Fill="Gold"
                        Stroke="Black"
                        StrokeThickness="1.5"
                        FontFamily="SegoeUI"
                        FontSize="26"
                        FontWeight="Bold"
                        Text="This is a Test of Outline Text" />
    </Canvas>
</Window>
